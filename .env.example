APP_NAME="D21 Panel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=https://panel.dvadsatjeden.org
APP_DOMAIN=panel.dvadsatjeden.org

# Standalone Deployment Ports (avoiding Passbolt conflict)
STANDALONE_HTTP_PORT=8080
STANDALONE_HTTPS_PORT=8443
ACME_EMAIL=admin@example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=d21panel
DB_USERNAME=d21panel
DB_PASSWORD=d21panel

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=panel.dvadsatjeden.org
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# BTCPay Server Configuration
BTCPAY_BASE_URL=https://satflux.org
BTCPAY_API_KEY=
BTCPAY_WEBHOOK_SECRET=

# Export Configuration
EXPORT_SIGNED_URL_TTL=3600

# LNURL Auth Configuration
LNURL_AUTH_ENABLED=false
LNURL_AUTH_DOMAIN=panel.dvadsatjeden.org

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=panel.dvadsatjeden.org
