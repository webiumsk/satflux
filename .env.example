# -----------------------------------------------------------------------------
# satflux.io - copy to `.env` and fill in real values. Never commit `.env`.
# Local Docker: see README.md (SANCTUM_STATEFUL_DOMAINS, SESSION_* for HTTP).
#
# PRODUCTION checklist (values below are LOCAL DEV defaults):
#   APP_ENV=production  APP_DEBUG=false  LOG_LEVEL=warning
#   SESSION_SECURE_COOKIE=true  SESSION_ENCRYPT=true  SESSION_DOMAIN=<your domain>
#   CSP_ENABLED=true (start with CSP_REPORT_ONLY=true, enforce after checking console)
# -----------------------------------------------------------------------------

APP_NAME="satflux.io"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080
APP_DOMAIN=localhost

# Standalone stack (docker-compose.standalone.yml + Caddy)
SITE_ADDRESS=localhost:80
ACME_EMAIL=admin@example.com
STANDALONE_HTTP_PORT=8090
STANDALONE_HTTPS_PORT=8443

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (docker-compose.yml defaults)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
# Defaults match docker-compose.yml (${DB_DATABASE:-satflux.io})
DB_DATABASE=satflux.io
DB_USERNAME=satflux.io
DB_PASSWORD=satflux.io

# Session / Sanctum SPA (production: set SESSION_DOMAIN, SECURE_COOKIE=true, ENCRYPT=true)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false   # Set to true in production to encrypt session data at rest
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Include exact browser host:port (see CLAUDE.md). Production: apex + www, e.g. satflux.io,www.satflux.io
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8000,localhost:8080,127.0.0.1:8000,127.0.0.1:8080,satflux.io,www.satflux.io

# Synthetic BTCPay emails: guest+<token>@<domain>. Defaults from APP_URL host; localhost/.local → guest.example.com.
# Production: set GUEST_EMAIL_DOMAIN=satflux.io (or your public host) if APP_URL is wrong for BTCPay.
# GUEST_EMAIL_DOMAIN=

# Broadcasting: null | log | reverb
BROADCAST_CONNECTION=log
# REVERB_APP_ID=
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http
# VITE_REVERB_APP_KEY=
# VITE_REVERB_HOST=
# VITE_REVERB_PORT=
# VITE_REVERB_SCHEME=
# VITE_APP_URL=

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Company SMTP SSRF guard: true only for local dev (Mailpit) or an internal relay.
# MUST stay false in production - otherwise the SMTP test endpoint can probe the internal network.
SMTP_ALLOW_PRIVATE_HOSTS=true

# Content-Security-Policy (config/security.php). Off for local dev (Vite dev server
# violates script-src 'self'). Production: CSP_ENABLED=true + CSP_REPORT_ONLY=true,
# click through the app watching the console, then set CSP_REPORT_ONLY=false.
CSP_ENABLED=false
CSP_REPORT_ONLY=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Local-first Evolu relay (WebSocket). Baked into the JS bundle at build time (not read from Laravel at runtime).
# deploy.sh passes this file to `npm run build` - use the same ENV_FILE on production (.env.standalone).
# Default in code when unset: wss://free.evoluhq.com
# Production: VITE_EVOLU_RELAY_URL=wss://evolu.satflux.io
# Users can override per account in Profile (evolu_relay_url) - takes priority over build default.
# VITE_EVOLU_RELAY_URL=wss://free.evoluhq.com
# Empty string VITE_EVOLU_RELAY_URL= disables cross-browser sync entirely.
# Vite dev: asset URLs served via nginx :8080 (see docker/nginx/default.conf)
# VITE_DEV_SERVER_ORIGIN=http://localhost:8080
#
# Local-first invoicing - set BOTH flags together (see docs/INVOICING_LOCAL_FIRST_ROLLOUT.md).
# VITE_* is compile-time (npm run build / deploy.sh); INVOICING_* is runtime (php artisan optimize:clear).
# Production: add to .env.standalone, then ./deploy.sh - do not enable on live without the rollout checklist.
# VITE_INVOICING_LOCAL_FIRST=true
# INVOICING_LOCAL_FIRST=true
# Force WooCommerce create-document into integration inbox (PoC; default false keeps BusinessDocument flow).
# WOOCOMMERCE_INBOX_MODE=true
# Satflux store UUID for the marketing landing Pay Button demo (BTCPay store ID resolved server-side).
# LANDING_PAY_DEMO_STORE_ID=
# Optional: public PoS iframe on the marketing landing page
# VITE_POS_DEMO_URL=https://your-btcpay.example.com/apps/YOUR_APP_ID/pos
# BTCPay Server - Greenfield API (server-side). May be internal, e.g. http://btcpay:49392 in Docker.
BTCPAY_BASE_URL=http://127.0.0.1:14142
# Browser-facing BTCPay origin for /raffle, PoS apps, pay links (GET /api/config → btcpay_base_url).
# MUST be the host where BTCPay serves /raffle (not the Satflux panel alone). If the panel and
# BTCPay share one hostname, proxy /raffle to BTCPay in nginx (see docker/nginx/btcpay-public.conf.example).
# BTCPAY_PUBLIC_URL=https://pay.example.com
# Optional: Lightning Address domain as user@domain when it differs from BTCPAY_BASE_URL host
# BTCPAY_LIGHTNING_ADDRESS_DOMAIN=pay.example.com
# Optional dev build hint only (normally unnecessary): VITE_BTCPAY_BASE_URL=http://127.0.0.1:14142
BTCPAY_API_KEY=
BTCPAY_WEBHOOK_SECRET=
# Webhook secret for SUBSCRIPTION_STORE_ID (falls back to BTCPAY_WEBHOOK_SECRET when unset)
SUBSCRIPTION_WEBHOOK_SECRET=

# Optional: Stripe Tax for US business invoicing (company can override in app settings)
# STRIPE_TAX_SECRET_KEY=sk_live_...

# Subscription checkout (BTCPay Plan offerings) - set in production if you sell plans
SUBSCRIPTION_SUCCESS_URL=
SUBSCRIPTION_CANCEL_URL=
ALLOW_GUEST_SUBSCRIPTIONS=false
# Greenfield store id (same as in BTCPay). Used by subscription checkout; optional scripts/create-subscription-store.php (copy from scripts/create-subscription-store.example.php)
SUBSCRIPTION_STORE_ID=
SUBSCRIPTION_OFFERING_ID=
SUBSCRIPTION_PLAN_PRO_ID=
SUBSCRIPTION_PLAN_ENTERPRISE_ID=
# Invoicing company UUID for auto-issued paid subscription invoices (internal runbook; not in public docs tree)
SUBSCRIPTION_BILLING_COMPANY_ID=

# Exports
EXPORT_SIGNED_URL_TTL=3600
LARAVEL_PDF_DRIVER=dompdf

# LNURL-Auth (LUD-04) - LNURL_AUTH_DOMAIN must be public HTTPS for wallet QR
LNURL_AUTH_ENABLED=false
LNURL_AUTH_DOMAIN=

# Guest trial purge (daily schedule 03:30). Deletes only when BOTH: no login in the window
# and no BTCPay invoices created on any guest store in that window. Enable only after ops review.
GUEST_PURGE_BATCH_SIZE=50
GUEST_PURGE_ENABLED=false
GUEST_PURGE_IDLE_DAYS=90
GUEST_PURGE_MAX_STORES_CHECK=10

# Seed-first onboarding: disable direct email/password registration (new users start with recovery phrase).
SEED_FIRST_REGISTRATION=true
# Guest → Free upgrade: email + verification only (defaults to SEED_FIRST_REGISTRATION when unset).
GUEST_UPGRADE_EMAIL_ONLY=true
# Frontend mirrors (Vite build-time; keep aligned with backend flags above).
VITE_SEED_FIRST_REGISTRATION=true
VITE_GUEST_UPGRADE_EMAIL_ONLY=true

# Nostr auth (optional)
NOSTR_AUTH_ENABLED=false
NOSTR_AUTH_CHALLENGE_TTL=300

# Optional: Discord webhook for support notifications
# SUPPORT_DISCORD_WEBHOOK_URL=

# Company registry autocomplete (invoicing)
# OPENREGISTRY_ENABLED=true
# OPENREGISTRY_BASE_URL=https://openregistry.sophymarine.com/api/v1
# Required for OpenRegistry autocomplete (server-side GET /api/v1/companies): https://openregistry.sophymarine.com/login
# OPENREGISTRY_BEARER_TOKEN=

# Invoicing: beta PRO company limit (production PRO = 2 in DB; leave unset when not in beta)
# INVOICING_BETA_PRO_MAX_COMPANIES=5
# INVOICING_EXPENSE_ISDOC_FREE_LIMIT=20

# Slovak e-faktura / Peppol (per-company credentials in app_settings; see docs/SK_EFAKTURA.md)
# EFAKTURA_ENABLED=false
# EFAKTURA_SAPI_BASE_URL=  # optional dev fallback; merchants set efaktura_sapi_base_url per company
# EFAKTURA_SAPI_ALLOWED_HOSTS=api.epostak.sk,dev.epostak.sk
# EFAKTURA_PROVIDER=sapi_sk
# EFAKTURA_INBOUND_POLL_LIMIT=20
# EFAKTURA_SAPI_SEND_DETAIL_PATH=/sapi/v1/document/send/{id}

# Data retention (daily 04:00, command data:retention-run). Enable after ops review.
# DATA_RETENTION_ENABLED=false
# DATA_RETENTION_WEBHOOK_EVENTS_DAYS=90
# DATA_RETENTION_AUDIT_LOGS_DAYS=730
# DATA_RETENTION_EXPORT_FILES_DAYS=30
# DATA_RETENTION_DRAFT_DOCUMENTS_DAYS=365
# DATA_RETENTION_SOFT_DELETED_COMPANIES_DAYS=30
# DATA_RETENTION_CANCELLED_EXPENSES_DAYS=90
# DATA_RETENTION_INTEGRATION_INBOX_CLOSED_DAYS=0
# DATA_RETENTION_CLEAR_PAYMENT_TOKEN_WHEN_PAID=true

# Bank payment matching - inbound email (b-mail style, phase 2)
# BANK_INBOUND_ENABLED=false
# BANK_INBOUND_WEBHOOK_SECRET=
# BANK_INBOUND_DOMAIN=payments.satflux.io
# BANK_INBOUND_ADDRESS_PREFIX=pay
# BANK_INBOUND_MAX_ADDRESS_LENGTH=50

# Wise bank sync (US/CA/AU/NZ/SG/MY - personal API token per company in app settings)
# WISE_API_BASE_URL=https://api.wise.com
# WISE_API_SANDBOX_URL=https://api.sandbox.transferwise.com
# WISE_USE_SANDBOX=false
# WISE_DEFAULT_SYNC_DAYS=30
# MAILGUN_WEBHOOK_SIGNING_KEY=   # Mailgun domain → Webhooks signing key (inbound route)
# MAILGUN_WEBHOOK_MAX_AGE_SECONDS=300
# BANK_IMPORT_FILE_RETENTION_DAYS=30

# Optional: Matomo analytics (omit both to disable tracking snippet)
# MATOMO_URL=https://analytics.example.com/matomo
# MATOMO_SITE_ID=1

# Chorala feedback widget (omit all to disable)
# CHORALA_PROJECT_KEY=pk_...
# CHORALA_WIDGET_THEME=dark            # light|dark - mirror Project -> Settings -> Widget appearance
# CHORALA_WIDGET_PRIMARY_COLOR=#1e3a5f
# CHORALA_API_KEY=hk_...               # Optional: auto-sync theme/accent from dashboard (admin API)
# CHORALA_PROJECT_ID=proj_...          # Optional with CHORALA_API_KEY; omit to resolve by pk_
# CHORALA_WIDGET_URL=https://chorala.com
# CHORALA_END_USER_JWT_SECRET=   # Project -> Settings in Chorala dashboard
# CHORALA_USE_PROXY=true         # Local dev default: proxy public API via /api/chorala-proxy (no CORS)
# Production: add https://satflux.io to Chorala Admin -> Project -> Settings -> Allowed origins
# Or set CHORALA_USE_PROXY=true on production until origins are configured

# Inertia (optional SSR)
# INERTIA_SSR_ENABLED=false
# INERTIA_SSR_URL=http://127.0.0.1:13714

# OFAC / sanctions compliance (off by default; see docs/OFAC_COMPLIANCE.md)
# COMPLIANCE_SCREENING_ENABLED=false
# COMPLIANCE_GEO_BLOCK_ENABLED=true
# COMPLIANCE_LIST_SCREENING_ENABLED=false
# COMPLIANCE_FAIL_CLOSED=true
# Local dev: loopback IPs are allowed when APP_ENV=local. To test geo-block use:
# COMPLIANCE_GEO_COUNTRY_OVERRIDE=IR
# MAXMIND_ACCOUNT_ID=
# MAXMIND_LICENSE_KEY=
# Then: php artisan compliance:update-geoip
# php artisan compliance:sync-sanctions-lists

# Error tracking (Sentry) - install via: composer require sentry/sentry-laravel
# Then run: php artisan sentry:publish --dsn=<your-dsn>
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
