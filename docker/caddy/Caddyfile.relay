# Evolu relay TLS site (optional). Generated by deploy.sh when RELAY_SITE_ADDRESS is set in .env.standalone.
# Manual: set RELAY_SITE_ADDRESS=relay.satflux.io and add a DNS A record to this VPS.

relay.satflux.io {
    reverse_proxy evolu-relay:4000
    log {
        output stdout
        format console
    }
}