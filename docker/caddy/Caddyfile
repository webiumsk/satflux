{
    # Global options
    email {$ACME_EMAIL}
}

{$APP_DOMAIN} {
    # Proxy all traffic to the nginx container
    reverse_proxy nginx:80

    # Enable logging
    log {
        output file /var/log/caddy/access.log
    }

    # Security headers are already handled by Nginx in prod.conf, 
    # but we can add more here if needed.
}
