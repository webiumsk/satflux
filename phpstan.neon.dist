includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 5

    tmpDir: storage/phpstan

    paths:
        - app

    # Existing findings are frozen in phpstan-baseline.neon - new code must be clean.
    # Regenerate after intentional cleanups: vendor/bin/phpstan analyse --generate-baseline
