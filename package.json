{
  "name": "satflux.io",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/fix-manifest.js",
    "preview": "vite preview",
    "lint": "eslint resources/js --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --max-warnings=52",
    "lint:fix": "eslint resources/js --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck": "node scripts/typecheck-baseline.mjs",
    "typecheck:update-baseline": "node scripts/typecheck-baseline.mjs --update",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:locale-parity": "node scripts/check-locale-parity.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },
  "dependencies": {
    "@evolu/common": "^7.4.1",
    "@evolu/vue": "^1.4.0",
    "@evolu/web": "^2.4.0",
    "@fontsource/outfit": "^5.2.8",
    "@inertiajs/vue3": "^3.6",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "@tiptap/extension-code-block-lowlight": "^2.10.0",
    "@tiptap/extension-color": "^2.10.0",
    "@tiptap/extension-heading": "^2.10.0",
    "@tiptap/extension-image": "^2.10.0",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-table": "^2.10.0",
    "@tiptap/extension-table-cell": "^2.10.0",
    "@tiptap/extension-table-header": "^2.10.0",
    "@tiptap/extension-table-row": "^2.10.0",
    "@tiptap/extension-text-align": "^2.27.2",
    "@tiptap/extension-text-style": "^2.10.0",
    "@tiptap/extension-underline": "^2.10.0",
    "@tiptap/extension-youtube": "^2.27.2",
    "@tiptap/pm": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "@tiptap/vue-3": "^2.10.0",
    "@types/qrcode": "^1.5.6",
    "axios": "^1.7.0",
    "bech32": "^2.0.0",
    "dompurify": "^3.4.12",
    "html5-qrcode": "^2.3.8",
    "laravel-echo": "^1.16.0",
    "lowlight": "^3.1.0",
    "nostr-tools": "^2.23.1",
    "pinia": "^2.1.7",
    "pusher-js": "^8.4.3",
    "qrcode": "^1.5.4",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.7",
    "vue-router": "^4.3.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^29.1.1",
    "laravel-vite-plugin": "^1.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^4.1.7",
    "vue-tsc": "^2.2.12"
  }
}
